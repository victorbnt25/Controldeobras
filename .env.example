# 🏗️ SISTEMA DE GESTIÓN DE REFORMAS
# Copiar este archivo como .env y modificar valores

# =============== ENTORNO ===============
APP_NAME="Sistema de Gestión de Reformas"
APP_ENV=development  # development, staging, production
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Madrid

# =============== DATABASE ===============
# MySQL
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=reformas_db
DB_USERNAME=root
DB_PASSWORD=root

# Para producción, cambiar a algo seguro:
# DB_PASSWORD=TuContraseñaSegura123!

# =============== BACKEND PHP ===============
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_POST_MAX_SIZE=100M
PHP_MAX_EXECUTION_TIME=300

# =============== FRONTEND REACT ===============
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_NAME="Gestión Reformas"
REACT_APP_VERSION=1.0.0
REACT_APP_ENV=development

# =============== EMAIL (Opcional) ===============
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_password_app
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@reformas.com
MAIL_FROM_NAME="Sistema Reformas"

# =============== UPLOADS ===============
UPLOAD_MAX_SIZE=104857600  # 100MB en bytes
UPLOAD_ALLOWED_TYPES=pdf,jpg,jpeg,png,xlsx,docx
UPLOAD_PATH=./uploads

# =============== REPORTS ===============
REPORTS_PATH=./reports
REPORT_RETENTION_DAYS=90  # Días que se guardan los reports

# =============== TARIFAS POR DEFECTO ===============
TARIFA_MEDIO_DIA=60.00
TARIFA_DIA_COMPLETO=120.00
TARIFA_SABADO=180.00  # 1.5x día normal

# =============== IVA POR DEFECTO ===============
IVA_POR_DEFECTO=21.00
IVA_REDUCIDO=10.00
IVA_SUPERREDUCIDO=4.00

# =============== SEGURIDAD ===============
APP_KEY=base64:tu_clave_secreta_aqui_32_caracteres
JWT_SECRET=tu_jwt_secret_aqui_minimo_32_caracteres

# =============== DOCKER (Opcional) ===============
COMPOSE_PROJECT_NAME=reformas
DOCKER_NETWORK_NAME=reformas_network
